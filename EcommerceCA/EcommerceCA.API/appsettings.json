{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=EcommerceCA;Trusted_Connection=True;TrustServerCertificate=True"
    // For Supabase/PostgreSQL, uncomment:
    // "DefaultConnection": "Host=your-db-host.supabase.co;Database=postgres;Username=postgres;Password=your-password;Port=5432;SSL Mode=Require;Trust Server Certificate=true"
  },
  "DatabaseProvider": "SqlServer", // Options: "SqlServer", "PostgreSQL"

  "Jwt": {
    "Secret":          "CHANGE_THIS_TO_A_VERY_LONG_RANDOM_SECRET_MIN_32_CHARS",
    "Issuer":          "EcommerceCA",
    "Audience":        "EcommerceCAClient",
    "ExpiryMinutes":   "60",
    "RefreshExpiryDays": "30"
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },

  "Stripe": {
    "SecretKey":      "sk_test_YOUR_STRIPE_SECRET_KEY",
    "PublishableKey": "pk_test_YOUR_STRIPE_PUBLISHABLE_KEY"
  },

  "Razorpay": {
    "KeyId":     "dummy_rzp_test_YOUR_KEY_ID",
    "KeySecret": "dummy_YOUR_KEY_SECRET"
  },

  "Twilio": {
    "AccountSid": "YOUR_ACCOUNT_SID",
    "AuthToken":  "YOUR_AUTH_TOKEN",
    "FromNumber": "+14155238886"
  },

  "Cloudinary": {
    "CloudName": "YOUR_CLOUD_NAME",
    "ApiKey":    "YOUR_API_KEY",
    "ApiSecret": "YOUR_API_SECRET"
  },

  "Email": {
    "Host":        "smtp.gmail.com",
    "Port":        "587",
    "Username":    "your@gmail.com",
    "Password":    "your-app-password",
    "FromAddress": "your@gmail.com"
  },

  "Frontend": {
    "BaseUrl": "http://localhost:3000"
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft":                       "Warning",
        "Microsoft.EntityFrameworkCore":   "Warning"
      }
    }
  },

  "AllowedHosts": "*"
}
